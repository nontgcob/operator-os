# RAGVLM / OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=OperatorOS
RAGVLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# Frontend / service URLs
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
ORCHESTRATOR_BASE_URL=http://localhost:8000
RAGVLM_SERVICE_URL=http://ragvlm-service:8001
VIDEO_SERVICE_URL=http://video-service:8002
SAM3_SERVICE_URL=http://sam3-service:8003
REDIS_URL=redis://redis:6379/0
USE_WORKER_QUEUE=false
MEDIA_INGEST_TIMEOUT_SECONDS=900

# Data locations inside Docker containers
RAGVLM_DOCUMENT_DIR=/app/data/ragvlm/documents
VIDEO_DATA_DIR=/app/data/video

# Whisper transcription
# Set false to skip Whisper model loading/download and use fallback timestamp transcripts during ingest.
WHISPER_ENABLED=false
WHISPER_MODEL=base

# YouTube / yt-dlp ingestion
# YouTube often requires browser cookies in Docker. Export them to ./data/ytdlp/cookies.txt and set:
# YTDLP_COOKIES_FILE=/app/data/ytdlp/cookies.txt
YTDLP_COOKIES_FILE=
YTDLP_USER_AGENT=

# JavaScript/EJS support for public YouTube extraction. The Docker image includes Deno.
YTDLP_JS_RUNTIME=deno:/usr/local/bin/deno
YTDLP_REMOTE_COMPONENTS=ejs:github

# Optional network/request tuning. These values mirror the current local demo tuning.
YTDLP_FORCE_IPV4=true
YTDLP_IMPERSONATE=
YTDLP_RETRIES=5
YTDLP_FRAGMENT_RETRIES=5
YTDLP_EXTRACTOR_RETRIES=3
YTDLP_SOCKET_TIMEOUT=30

# Raw yt-dlp extractor args, plus first-class YouTube PO-token tuning hooks.
YTDLP_EXTRACTOR_ARGS=
YTDLP_YOUTUBE_PLAYER_CLIENTS=mweb,default
YTDLP_YOUTUBE_FETCH_PO_TOKEN=auto
YTDLP_PO_TOKEN_PROVIDER_ARGS=

# SAM3 tracking
SAM3_TRACKING_BACKEND=sam3
SAM3_VIDEO_ROOT=/app/data/video
SAM3_CHECKPOINT_PATH=
SAM3_DEVICE=
SAM3_ALLOW_HF_DOWNLOAD=false
SAM3_ALLOW_SIMULATION_FALLBACK=false
SAM3_MAX_PROPAGATION_FRAMES=20
SAM3_FRAME_INTERVAL_SECONDS=1.0
SAM3_SIMULATION_STEPS=10
SAM3_SIMULATION_DELAY_SECONDS=0.35
