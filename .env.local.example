# OperatorOS local no-Docker defaults.
# Copy to .env for local development and fill OPENROUTER_API_KEY.

OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=OperatorOS
RAGVLM_EMBEDDING_MODEL=openai/text-embedding-3-small

NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
ORCHESTRATOR_BASE_URL=http://localhost:8000
RAGVLM_SERVICE_URL=http://localhost:8001
VIDEO_SERVICE_URL=http://localhost:8002
SAM3_SERVICE_URL=http://localhost:8003

USE_REDIS_STATE=false
USE_WORKER_QUEUE=false
MEDIA_INGEST_TIMEOUT_SECONDS=900

RAGVLM_DOCUMENT_DIR=./data/ragvlm/documents
VIDEO_DATA_DIR=./data/video

WHISPER_ENABLED=true
WHISPER_MODEL=base

YTDLP_COOKIES_FILE=
YTDLP_USER_AGENT=
YTDLP_JS_RUNTIME=
YTDLP_REMOTE_COMPONENTS=
YTDLP_FORCE_IPV4=false
YTDLP_IMPERSONATE=
YTDLP_RETRIES=5
YTDLP_FRAGMENT_RETRIES=5
YTDLP_EXTRACTOR_RETRIES=3
YTDLP_SOCKET_TIMEOUT=30
YTDLP_EXTRACTOR_ARGS=
YTDLP_YOUTUBE_PLAYER_CLIENTS=mweb,default
YTDLP_YOUTUBE_FETCH_PO_TOKEN=auto
YTDLP_PO_TOKEN_PROVIDER_ARGS=

SAM3_TRACKING_BACKEND=sam3
SAM3_VIDEO_ROOT=./data/video
SAM3_CHECKPOINT_PATH=./models/sam3.pt
SAM3_DEVICE=
SAM3_ALLOW_HF_DOWNLOAD=false
SAM3_ALLOW_SIMULATION_FALLBACK=false
SAM3_MAX_PROPAGATION_FRAMES=20
SAM3_FRAME_INTERVAL_SECONDS=1.0
SAM3_MAX_POLYGON_POINTS=160
SAM3_SIMULATION_STEPS=10
SAM3_SIMULATION_DELAY_SECONDS=0.35
